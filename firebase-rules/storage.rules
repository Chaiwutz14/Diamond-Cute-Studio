rules_version = '2';

// Diamond Cute Studio — Firebase Storage Rules (V3)
// ใช้เมื่อย้ายสลิป/รูปลูกค้าไปเก็บแบบ private (ตั้ง PRIVATE_UPLOADS:true ใน config.js)
// แทน ImgBB สาธารณะ — เฉพาะแอดมินเท่านั้นที่อ่านสลิป/รูปได้

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      // ⚠️ แก้อีเมลให้ตรงกับที่ตั้งใน config.js (ADMIN_EMAIL) และใน firestore.rules
      return request.auth != null
        && request.auth.token.email == 'REPLACE_WITH_ADMIN_EMAIL@example.com';
    }

    // สลิปโอนเงิน + รูปงานลูกค้า: ลูกค้าอัปได้ (จำกัดขนาด/ชนิด) แต่ "อ่านได้เฉพาะแอดมิน"
    match /orders/{orderId}/{fileName} {
      allow create: if request.resource.size < 8 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow read:   if isAdmin();           // ← สลิปไม่สาธารณะอีกต่อไป
      allow update, delete: if isAdmin();
    }

    // ปฏิเสธอย่างอื่นทั้งหมด
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
