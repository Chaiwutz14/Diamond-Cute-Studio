rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── สินค้า ───
    match /products/{id}   { allow read, write: if true; }

    // ─── ออเดอร์ ───
    // ลูกค้าสร้างได้ (ตรวจ field สำคัญ + ต้องเริ่มที่ pending)
    match /orders/{id} {
      allow create: if
        request.resource.data.keys().hasAll([
          'orderId','customerName','customerPhone',
          'address','total','status','createdAt'
        ]) &&
        request.resource.data.customerName is string &&
        request.resource.data.customerName.size() > 0 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.status == 'pending';
      allow read, update, delete: if true;
    }

    // ─── รีวิว ───
    // ลูกค้าสร้างได้ → ต้อง pending เท่านั้น (Admin อนุมัติทีหลัง)
    match /reviews/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['name','rating','text','status','createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 40 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() >= 10 &&
        request.resource.data.text.size() <= 500 &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'approved');
      allow read, update, delete: if true;
    }

    // ─── เนื้อหาเว็บไซต์ (CMS) ───
    match /siteContent/{id} { allow read, write: if true; }

    // ─── เทมเพลตกรอบรูปของร้าน ───
    match /templates/{id}   { allow read, write: if true; }

    // ─── อื่นๆ ───
    match /categories/{id}  { allow read, write: if true; }
    match /gallery/{id}     { allow read, write: if true; }
    match /contacts/{id}    { allow read, write: if true; }
    match /settings/{id}    { allow read, write: if true; }
  }
}
