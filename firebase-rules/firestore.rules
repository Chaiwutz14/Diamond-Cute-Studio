rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Products ───
    // อ่านได้ทุกคน, เขียนได้ทุกคน (Admin ใช้ผ่าน browser)
    match /products/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ─── Orders ───
    // ลูกค้าสร้างได้, Admin อ่าน/แก้/ลบได้ทั้งหมด
    match /orders/{id} {
      allow read, write: if true;
    }

    // ─── Categories ───
    match /categories/{id} {
      allow read, write: if true;
    }

    // ─── Settings ───
    match /settings/{id} {
      allow read, write: if true;
    }
  }
}
